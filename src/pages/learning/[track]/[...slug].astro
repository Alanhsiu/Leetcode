---
import { render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LevelBadge from "../../../components/LevelBadge.astro";
import ProgressControls from "../../../components/ProgressControls.astro";
import { href } from "../../../lib/url";
import {
  getLearning, getTrackView, trackSlug, guideSlug, isLanding, guideProgressId,
} from "../../../lib/learning";
import { trackMeta, humanizeTrack } from "../../../data/tracks";
import { articleLd, breadcrumbLd } from "../../../lib/seo";

export async function getStaticPaths() {
  const all = await getLearning();
  return all
    .filter((e) => !isLanding(e))
    .map((e) => ({ params: { track: trackSlug(e), slug: guideSlug(e) }, props: { id: e.id } }));
}

const { id } = Astro.props;
const all = await getLearning();
const entry = all.find((e) => e.id === id)!;
const tslug = trackSlug(entry);
const tmeta = trackMeta(tslug) ?? { slug: tslug, title: humanizeTrack(tslug), icon: "📘", blurb: "", order: 99 };

const view = await getTrackView(tslug);
const ordered = view?.guides ?? [];
const idx = ordered.findIndex((g) => g.id === entry.id);
const prev = idx > 0 ? ordered[idx - 1] : null;
const next = idx >= 0 && idx < ordered.length - 1 ? ordered[idx + 1] : null;

const { Content } = await render(entry);
const progressId = guideProgressId(entry);
const guideUrl = href(`/learning/${tmeta.slug}/${guideSlug(entry)}`);
const guideDesc = entry.data.description || `${tmeta.title} — ${entry.data.title}`;
const jsonLd = [
  articleLd({ headline: entry.data.title, description: guideDesc, url: guideUrl, type: "TechArticle" }),
  breadcrumbLd([
    { name: "Learning", url: href("/learning") },
    { name: tmeta.title, url: href(`/learning/${tmeta.slug}`) },
    { name: entry.data.title, url: guideUrl },
  ]),
];
---
<BaseLayout title={entry.data.title} description={guideDesc} type="article" jsonLd={jsonLd}>
  <nav class="text-sm muted mb-4">
    <a href={href("/learning")} class="hover:text-[var(--accent)]">Learning</a>
    <span class="mx-1">/</span>
    <a href={href(`/learning/${tmeta.slug}`)} class="hover:text-[var(--accent)]">{tmeta.title}</a>
    <span class="mx-1">/</span>
    <span>{entry.data.title}</span>
  </nav>

  <header class="mb-5">
    <div class="flex flex-wrap items-center gap-2">
      <h1 class="text-2xl sm:text-3xl font-bold">{entry.data.title}</h1>
      <LevelBadge level={entry.data.level} />
    </div>
    {entry.data.description && <p class="muted mt-2">{entry.data.description}</p>}
    {entry.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-3 text-xs">
        {entry.data.tags.map((t) => <span class="badge badge-tag">{t}</span>)}
      </div>
    )}
  </header>

  <article class="prose">
    <Content />
  </article>

  <section class="surface rounded-xl p-4 mt-8 flex items-center justify-between gap-3 flex-wrap">
    <span class="text-sm muted">Mark your progress with this guide:</span>
    <ProgressControls slug={progressId} size="sm" />
  </section>

  <nav class="flex justify-between gap-3 mt-8 pt-6 border-t border-token text-sm">
    {prev ? (
      <a href={href(`/learning/${tmeta.slug}/${guideSlug(prev)}`)} class="viz-btn flex-1 !justify-start">← {prev.data.title}</a>
    ) : <a href={href(`/learning/${tmeta.slug}`)} class="viz-btn flex-1 !justify-start">← {tmeta.title} outline</a>}
    {next ? (
      <a href={href(`/learning/${tmeta.slug}/${guideSlug(next)}`)} class="viz-btn flex-1 !justify-end text-right">{next.data.title} →</a>
    ) : <span></span>}
  </nav>
</BaseLayout>
