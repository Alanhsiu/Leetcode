---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { href } from "../../lib/url";
import { getCheatsheetGroups } from "../../lib/content";

const groups = getCheatsheetGroups();
const GROUP_LABELS: Record<string, string> = {
  CS: "Computer Science",
  EDA: "EDA / Chip Design",
  GPU: "GPU Programming",
  HW: "Hardware / VLSI",
};
---
<BaseLayout title="Cheat Sheets" description="Topic cheat sheets across CS, EDA, GPU, and hardware." wide>
  <header class="mb-6">
    <h1 class="text-3xl font-bold">Cheat Sheets</h1>
    <p class="muted mt-1">Concept refreshers across CS fundamentals, EDA, GPU, and hardware.</p>
  </header>
  <div class="grid gap-6">
    {groups.map((g) => (
      <section>
        <h2 class="font-semibold text-lg mb-3">{GROUP_LABELS[g.group] ?? g.group}</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {g.items.map((c) => (
            <a href={href(`/cheatsheets/${c.slug}`)} class="card p-4 block">
              <h3 class="font-semibold">{c.title}</h3>
              <p class="muted text-xs mt-1 uppercase tracking-wide">{c.group}{c.isCode ? " · code" : ""}</p>
            </a>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
