---
import { render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import LevelBadge from "../../../components/LevelBadge.astro";
import { href } from "../../../lib/url";
import { getTrackViews, getTrackView, guideSlug, guideProgressId } from "../../../lib/learning";

export async function getStaticPaths() {
  const views = await getTrackViews();
  return views.map((v) => ({ params: { track: v.meta.slug } }));
}

const { track } = Astro.params;
const view = await getTrackView(track!);
if (!view) return Astro.redirect(href("/learning"));
const { meta, landing, guides, aiGenerated } = view;
const Landing = landing ? (await render(landing)).Content : null;
---
<BaseLayout title={meta.title} description={meta.blurb} wide>
  <nav class="text-sm muted mb-4">
    <a href={href("/learning")} class="hover:text-[var(--accent)]">Learning</a>
    <span class="mx-1">/</span>
    <span>{meta.title}</span>
  </nav>

  <header class="mb-6">
    <div class="flex items-center gap-3 flex-wrap">
      <span class="text-3xl" aria-hidden="true">{meta.icon}</span>
      <h1 class="text-3xl font-bold">{meta.title}</h1>
      {aiGenerated && <span class="badge badge-medium" title="Contains AI-drafted content to verify">⚠ AI-drafted</span>}
    </div>
    <p class="mt-2 muted max-w-2xl">{meta.blurb}</p>
  </header>

  {Landing && (
    <section class="prose mb-8">
      <Landing />
    </section>
  )}

  <section>
    <h2 class="font-semibold mb-3 text-sm uppercase tracking-wide muted">Outline · {guides.length} guides</h2>
    {guides.length === 0 ? (
      <p class="muted text-sm">No guides yet.</p>
    ) : (
      <ol class="grid gap-2">
        {guides.map((g, i) => (
          <li>
            <a href={href(`/learning/${meta.slug}/${guideSlug(g)}`)} class="card p-3 flex items-center gap-3 text-sm">
              <span class="muted font-mono text-xs w-6 text-right">{i + 1}</span>
              <span class="progress-dot muted shrink-0" data-progress-indicator={guideProgressId(g)}>○</span>
              <span class="flex-1">
                <span class="font-medium">{g.data.title}</span>
                {g.data.description && <span class="muted block text-xs mt-0.5">{g.data.description}</span>}
              </span>
              {g.data.aiGenerated && <span class="badge badge-tag" title="AI-drafted">AI</span>}
              <LevelBadge level={g.data.level} />
            </a>
          </li>
        ))}
      </ol>
    )}
  </section>
</BaseLayout>
