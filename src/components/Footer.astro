---
import { href } from "../lib/url";
---
<footer class="border-t border-token mt-16">
  <div class="mx-auto max-w-7xl px-4 py-8 text-sm muted flex flex-col sm:flex-row gap-3 justify-between">
    <p>
      <span class="font-semibold">PrepKit</span> — an interview-prep platform. Built with
      <a class="underline" href="https://astro.build" rel="noopener">Astro</a>.
      Problem statements are © LeetCode — only titles, facts, links, and original notes are shown.
    </p>
    <nav class="flex gap-4" aria-label="Footer">
      <a class="hover:text-[var(--accent)]" href={href("/problems")}>Problems</a>
      <a class="hover:text-[var(--accent)]" href={href("/neetcode150")}>NeetCode 150</a>
      <a class="hover:text-[var(--accent)]" href={href("/dashboard")}>Dashboard</a>
      <a class="hover:text-[var(--accent)]" href="https://github.com/Alanhsiu/prepkit" rel="noopener">GitHub</a>
    </nav>
  </div>
</footer>
