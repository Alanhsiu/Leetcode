---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CodeBlock from "../../components/CodeBlock.astro";
import CodeRunner from "../../components/CodeRunner.astro";
import DifficultyBadge from "../../components/DifficultyBadge.astro";
import ProgressControls from "../../components/ProgressControls.astro";
import { getProblems } from "../../lib/content";
import { href, slugify } from "../../lib/url";
import { CATEGORY_VIZ } from "../../lib/patterns";
import { renderMarkdown } from "../../lib/markdown";
import { buildDriver } from "../../lib/driver";
import { articleLd, breadcrumbLd } from "../../lib/seo";

export function getStaticPaths() {
  const problems = getProblems();
  return problems.map((p, i) => ({
    params: { slug: p.routeSlug },
    props: {
      problem: p,
      prev: i > 0 ? problems[i - 1] : null,
      next: i < problems.length - 1 ? problems[i + 1] : null,
    },
  }));
}

const { problem: p, prev, next } = Astro.props;
const related = getProblems()
  .filter((q) => q.routeSlug !== p.routeSlug && q.patterns.some((x) => p.patterns.includes(x)))
  .slice(0, 6);
const vizIds = p.patterns.flatMap((pat) => CATEGORY_VIZ[pat] ?? []);
const sourceLabel = p.aiGenerated ? "Standard solution only" : p.source === "neetcode" ? "NeetCode 150" : "Misc";
const approachHtml = p.standard?.approach ? await renderMarkdown(p.standard.approach) : "";
// Run the playground against whichever solution we show first.
const runCode = p.standard?.code ?? p.mySolution?.code ?? p.code;
const driver = buildDriver(runCode);
const pageUrl = href(`/problems/${p.routeSlug}`);
const pageDesc = `C++ solution and notes for LeetCode ${p.number}. ${p.title} — pattern: ${p.patterns.join(", ")}.`;
const jsonLd = [
  articleLd({ headline: `${p.number}. ${p.title}`, description: pageDesc, url: pageUrl, type: "TechArticle" }),
  breadcrumbLd([
    { name: "Problems", url: href("/problems") },
    { name: `${p.number}. ${p.title}`, url: pageUrl },
  ]),
];
---
<BaseLayout title={`${p.number}. ${p.title}`} description={pageDesc} type="article" jsonLd={jsonLd}>
  <nav class="text-sm muted mb-4">
    <a href={href("/problems")} class="hover:text-[var(--accent)]">Problems</a>
    <span class="mx-1">/</span>
    <span>{p.number}. {p.title}</span>
  </nav>

  <header class="mb-6">
    <div class="flex flex-wrap items-center gap-2">
      <h1 class="text-2xl sm:text-3xl font-bold">
        <span class="muted font-mono">{p.number}.</span> {p.title}
      </h1>
      <DifficultyBadge difficulty={p.difficulty} />
      {p.inNeetCode150 && <span class="badge badge-tag">NeetCode 150</span>}
    </div>
    <div class="flex flex-wrap items-center gap-1.5 mt-3 text-xs">
      {p.patterns.map((pat) => (
        <a href={href(`/patterns/${slugify(pat)}`)} class="badge badge-tag hover:text-[var(--accent)]">{pat}</a>
      ))}
      {p.timeComplexity && <span class="badge badge-complexity">Time {p.timeComplexity}</span>}
      {p.spaceComplexity && <span class="badge badge-complexity">Space {p.spaceComplexity}</span>}
    </div>
    <div class="flex flex-wrap items-center gap-3 mt-4 text-sm">
      <a href={p.leetcodeUrl} target="_blank" rel="noopener" class="viz-btn !text-xs">↗ Open on LeetCode</a>
      <span class="muted text-xs">Source: {sourceLabel}</span>
    </div>
  </header>

  <!-- Quick review -->
  <section class="surface rounded-xl p-4 mb-6">
    <div class="flex items-center justify-between gap-3 flex-wrap">
      <h2 class="font-semibold text-sm uppercase tracking-wide muted">Quick review</h2>
      <ProgressControls slug={p.routeSlug} size="sm" />
    </div>
    <dl class="grid sm:grid-cols-3 gap-3 mt-3 text-sm">
      <div><dt class="muted text-xs uppercase">Pattern</dt><dd class="font-medium">{p.patterns.join(", ")}</dd></div>
      <div><dt class="muted text-xs uppercase">Time</dt><dd class="font-mono">{p.timeComplexity ?? "—"}</dd></div>
      <div><dt class="muted text-xs uppercase">Space</dt><dd class="font-mono">{p.spaceComplexity ?? "—"}</dd></div>
    </dl>
  </section>

  <!-- (a) Standard Solution: clean canonical reference -->
  {p.standard ? (
    <section class="mb-8" id="standard-solution">
      <div class="flex items-center gap-2 mb-2">
        <h2 class="font-semibold">Standard Solution <span class="muted font-normal text-sm">(C++)</span></h2>
      </div>
      {p.standard.summary && (
        <p class="mb-3"><span class="muted text-xs uppercase tracking-wide block mb-1">Summary</span>{p.standard.summary}</p>
      )}
      {approachHtml && (
        <div class="mb-3">
          <span class="muted text-xs uppercase tracking-wide block mb-1">Approach</span>
          <div class="prose prose-sm" set:html={approachHtml} />
        </div>
      )}
      <CodeBlock code={p.standard.code} lang="cpp" />
      <div class="flex flex-wrap items-center gap-1.5 mt-2 text-xs">
        {p.standard.timeComplexity && <span class="badge badge-complexity">Time {p.standard.timeComplexity}</span>}
        {p.standard.spaceComplexity && <span class="badge badge-complexity">Space {p.standard.spaceComplexity}</span>}
      </div>
      <p class="muted text-xs mt-2">A canonical reference solution. Problem statement © LeetCode — see the official link above.</p>
    </section>
  ) : (
    <section class="surface rounded-xl p-4 mb-8">
      <p class="muted text-sm">A standard reference solution for this problem is coming soon.</p>
    </section>
  )}

  {vizIds.length > 0 && (
    <section class="mb-6" id="viz-embed">
      <h2 class="font-semibold mb-2">Visualize the pattern</h2>
      <div data-viz-mount={vizIds[0]}></div>
    </section>
  )}

  <!-- (b) My Solution: my original note/code, where I have one -->
  {p.mySolution && (
    <section id="my-solution">
      <h2 class="font-semibold mb-2">My Solution <span class="muted font-normal text-sm">(C++)</span></h2>
      <CodeBlock code={p.mySolution.code} lang="cpp" />
      <div class="flex flex-wrap items-center gap-1.5 mt-2 text-xs">
        {p.mySolution.timeComplexity && <span class="badge badge-complexity">Time {p.mySolution.timeComplexity}</span>}
        {p.mySolution.spaceComplexity && <span class="badge badge-complexity">Space {p.mySolution.spaceComplexity}</span>}
      </div>
      <p class="muted text-xs mt-2">My own solution and notes, as I wrote them.</p>
    </section>
  )}

  <!-- Run it -->
  <section class="mt-6">
    <details class="surface rounded-xl overflow-hidden">
      <summary class="cursor-pointer list-none p-4 flex items-center gap-2 flex-wrap">
        <span class="font-semibold">▶ Run it</span>
        <span class="muted text-sm">— editable in-browser playground{driver.runnable ? " with a sample driver" : ""}</span>
        <span class="ml-auto badge badge-complexity">C++</span>
      </summary>
      <div class="px-4 pb-4">
        <p class="muted text-xs mb-3">
          {driver.runnable
            ? "Your solution plus an auto-generated main() and sample input so Run produces output. The driver and inputs are unverified — edit freely; Reset restores this starting point."
            : "Your solution. A driver couldn't be auto-generated for this signature — add a main() that calls the method and prints the result, then Run."}
        </p>
        <CodeRunner code={driver.fullCode} language="cpp" note={driver.note} />
      </div>
    </details>
  </section>

  {related.length > 0 && (
    <section class="mt-10">
      <h2 class="font-semibold mb-3">Related — same pattern</h2>
      <div class="grid gap-2 sm:grid-cols-2">
        {related.map((r) => (
          <a href={href(`/problems/${r.routeSlug}`)} class="card p-3 flex items-center gap-2 text-sm">
            <span class="progress-dot muted" data-progress-indicator={r.routeSlug}>○</span>
            <span class="flex-1"><span class="muted font-mono">{r.number}.</span> {r.title}</span>
            <DifficultyBadge difficulty={r.difficulty} />
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- Prev / next -->
  <nav class="flex justify-between gap-3 mt-10 pt-6 border-t border-token text-sm">
    {prev ? (
      <a href={href(`/problems/${prev.routeSlug}`)} class="viz-btn flex-1 !justify-start">← {prev.number}. {prev.title}</a>
    ) : <span></span>}
    {next ? (
      <a href={href(`/problems/${next.routeSlug}`)} class="viz-btn flex-1 !justify-end text-right">{next.number}. {next.title} →</a>
    ) : <span></span>}
  </nav>
</BaseLayout>

<script>
  import { mountViz } from "../../scripts/viz-loader.ts";
  document.querySelectorAll<HTMLElement>("[data-viz-mount]").forEach((el) => {
    mountViz(el, el.dataset.vizMount!);
  });
</script>
