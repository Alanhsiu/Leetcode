---
// Difficulty/level badge for guides â€” reuses the same badge palette as problems
// (Beginnerâ‰ˆEasy, Intermediateâ‰ˆMedium, Advancedâ‰ˆHard).
interface Props { level?: string; }
const { level } = Astro.props;
const cls =
  level === "Beginner" ? "badge-easy"
  : level === "Intermediate" ? "badge-medium"
  : level === "Advanced" ? "badge-hard"
  : "badge-tag";
---
{level && <span class:list={["badge", cls]}>{level}</span>}
