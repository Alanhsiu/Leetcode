---
import BaseLayout from "../layouts/BaseLayout.astro";
import CodeBlock from "../components/CodeBlock.astro";
import DifficultyBadge from "../components/DifficultyBadge.astro";
import LevelBadge from "../components/LevelBadge.astro";
import ProgressControls from "../components/ProgressControls.astro";
import { href } from "../lib/url";
import { getProblems } from "../lib/content";
import { PATTERNS } from "../lib/patterns";
import { getTrackViews, guideProgressId, guideSlug } from "../lib/learning";

const problems = getProblems();
const byPattern = PATTERNS.map((pat) => ({
  pattern: pat,
  items: problems.filter((p) => p.patterns.includes(pat.name)),
})).filter((g) => g.items.length > 0);
const trackViews = (await getTrackViews()).filter((t) => t.guides.length > 0);
---
<BaseLayout title="Cram Mode" description="Rapid revision: every solution collapsed to its pattern and complexity, expandable to full code." wide>
  <header class="mb-5">
    <h1 class="text-3xl font-bold">Cram Mode</h1>
    <p class="muted mt-1">Each problem (and learning guide) is collapsed to its key facts. Expand for the full solution. Great for a last-minute pass.</p>
  </header>

  <div class="surface rounded-xl p-3 mb-6 sticky top-16 z-30 flex flex-wrap gap-3 items-center backdrop-blur" style="background: color-mix(in srgb, var(--bg-card) 92%, transparent);">
    <select id="cram-status" class="surface-elev border border-token rounded-lg px-3 py-1.5 text-sm" aria-label="Filter by status">
      <option value="">All problems</option>
      <option value="review">Needs review</option>
      <option value="none">Not started</option>
      <option value="solved">Solved</option>
      <option value="confident">Confident</option>
    </select>
    <button id="expand-all" class="viz-btn !text-sm">Expand all</button>
    <button id="collapse-all" class="viz-btn !text-sm">Collapse all</button>
    <span class="ml-auto muted text-xs"><span id="cram-count">{problems.length}</span> shown</span>
  </div>

  <div class="grid gap-8">
    {byPattern.map((g) => (
      <section data-pattern-group={g.pattern.slug}>
        <h2 class="font-semibold mb-2 sticky top-32 z-20">
          <a href={href(`/patterns/${g.pattern.slug}`)} class="hover:text-[var(--accent)]">{g.pattern.name}</a>
          <span class="muted text-sm font-normal">({g.items.length})</span>
        </h2>
        <div class="grid gap-2">
          {g.items.map((p) => (
            <details class="card overflow-hidden" data-cram data-slug={p.routeSlug}>
              <summary class="flex items-center gap-2 p-3 cursor-pointer list-none">
                <span class="progress-dot muted shrink-0" data-progress-indicator={p.routeSlug}>○</span>
                <span class="flex-1 text-sm font-medium"><span class="muted font-mono">{p.number}.</span> {p.title}</span>
                {p.timeComplexity && <span class="badge badge-complexity hidden sm:inline">⏱ {p.timeComplexity}</span>}
                <DifficultyBadge difficulty={p.difficulty} />
              </summary>
              <div class="px-3 pb-3 border-t border-token pt-3">
                <div class="flex flex-wrap items-center gap-2 mb-3 text-xs">
                  {p.patterns.map((pat) => <span class="badge badge-tag">{pat}</span>)}
                  {p.timeComplexity && <span class="badge badge-complexity">Time {p.timeComplexity}</span>}
                  {p.spaceComplexity && <span class="badge badge-complexity">Space {p.spaceComplexity}</span>}
                  <a href={href(`/problems/${p.routeSlug}`)} class="ml-auto hover:text-[var(--accent)]">Open full note →</a>
                </div>
                <CodeBlock code={p.code} lang="cpp" />
                <div class="mt-3"><ProgressControls slug={p.routeSlug} size="sm" /></div>
              </div>
            </details>
          ))}
        </div>
      </section>
    ))}

    {trackViews.length > 0 && (
      <h2 class="text-lg font-bold pt-4 border-t border-token">📚 Learning guides</h2>
    )}
    {trackViews.map((t) => (
      <section data-pattern-group={`learn-${t.meta.slug}`}>
        <h2 class="font-semibold mb-2 sticky top-32 z-20">
          <a href={href(`/learning/${t.meta.slug}`)} class="hover:text-[var(--accent)]">{t.meta.icon} {t.meta.title}</a>
          <span class="muted text-sm font-normal">({t.guides.length})</span>
        </h2>
        <div class="grid gap-2">
          {t.guides.map((g) => (
            <details class="card overflow-hidden" data-cram data-slug={guideProgressId(g)}>
              <summary class="flex items-center gap-2 p-3 cursor-pointer list-none">
                <span class="progress-dot muted shrink-0" data-progress-indicator={guideProgressId(g)}>○</span>
                <span class="flex-1 text-sm font-medium">{g.data.title}</span>
                {g.data.aiGenerated && <span class="badge badge-tag hidden sm:inline" title="AI-drafted">AI</span>}
                <LevelBadge level={g.data.level} />
              </summary>
              <div class="px-3 pb-3 border-t border-token pt-3 text-sm">
                <p class="muted">{g.data.description}</p>
                <div class="flex flex-wrap items-center gap-2 mt-2 text-xs">
                  {g.data.tags.map((tag) => <span class="badge badge-tag">{tag}</span>)}
                  <a href={href(`/learning/${t.meta.slug}/${guideSlug(g)}`)} class="ml-auto hover:text-[var(--accent)]">Open guide →</a>
                </div>
                <div class="mt-3"><ProgressControls slug={guideProgressId(g)} size="sm" /></div>
              </div>
            </details>
          ))}
        </div>
      </section>
    ))}
  </div>
</BaseLayout>

<script>
  const items = Array.from(document.querySelectorAll<HTMLElement>("[data-cram]"));
  const statusSel = document.getElementById("cram-status") as HTMLSelectElement;
  const countEl = document.getElementById("cram-count")!;

  function progress(): Record<string, string> {
    try { return JSON.parse(localStorage.getItem("dsa-progress") || "{}"); } catch { return {}; }
  }
  function apply() {
    const want = statusSel.value;
    const prog = progress();
    let shown = 0;
    for (const el of items) {
      const st = prog[el.dataset.slug!];
      let ok = true;
      if (want === "none") ok = !st;
      else if (want) ok = st === want;
      el.style.display = ok ? "" : "none";
      if (ok) shown++;
    }
    countEl.textContent = String(shown);
    // hide empty pattern groups
    document.querySelectorAll<HTMLElement>("[data-pattern-group]").forEach((g) => {
      const any = Array.from(g.querySelectorAll<HTMLElement>("[data-cram]")).some((d) => d.style.display !== "none");
      g.style.display = any ? "" : "none";
    });
  }
  statusSel.addEventListener("change", apply);
  document.addEventListener("progress-changed", apply);
  document.getElementById("expand-all")?.addEventListener("click", () => items.forEach((d) => (d as HTMLDetailsElement).open = true));
  document.getElementById("collapse-all")?.addEventListener("click", () => items.forEach((d) => (d as HTMLDetailsElement).open = false));
  apply();
</script>
