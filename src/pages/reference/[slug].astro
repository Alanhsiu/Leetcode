---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { href } from "../../lib/url";
import { getReference } from "../../lib/content";
import { renderMarkdown } from "../../lib/markdown";

export async function getStaticPaths() {
  return getReference().map((r) => ({ params: { slug: r.slug }, props: { ref: r } }));
}
const { ref } = Astro.props;
const html = await renderMarkdown(ref.body);
---
<BaseLayout title={ref.title} description={`C++ reference: ${ref.title}.`}>
  <nav class="text-sm muted mb-4">
    <a href={href("/reference")} class="hover:text-[var(--accent)]">Reference</a>
    <span class="mx-1">/</span><span class="font-mono">{ref.title}</span>
  </nav>
  <article class="prose" set:html={html} />
</BaseLayout>
